// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: artifacts/{appId}/users/{userId}/deployments
// Document ID: auto-generated
// Fields:
//   - repoName: string (required)
//   - status: string (required, enum: PASS, FAIL)
//   - maturity: string (optional)
//   - timestamp: timestamp (required)
//   - summary: string (optional)
//   - uiUrl: string (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidDeployment(data) {
      return data.repoName is string && data.repoName.size() > 0 && data.repoName.size() < 200 &&
             data.status in ['PASS', 'FAIL'] &&
             data.timestamp is timestamp &&
             (!('maturity' in data) || (data.maturity is string && data.maturity.size() < 100)) &&
             (!('summary' in data) || (data.summary is string && data.summary.size() < 1000)) &&
             (!('uiUrl' in data) || (data.uiUrl is string && data.uiUrl.size() < 2000000)); // Allow large base64
    }

    match /artifacts/{appId}/users/{userId}/deployments/{deploymentId} {
      allow read, write: if isOwner(userId) && (request.method != 'create' && request.method != 'update' || isValidDeployment(request.resource.data));
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
